# The SEEDED demo board runs fully with ZERO keys. Everything here is optional
# and only powers the LIVE board / live AI features. Visitors can also supply
# their own Anthropic/Apify/Firecrawl keys from the Connections page instead.

# AI Analyst, Reports, Ad Intelligence creative analysis
ANTHROPIC_API_KEY=

# Ad Library scraping (apify/facebook-ads-scraper)
APIFY_TOKEN=

# Landing-page funnel notes in Ad Intelligence
FIRECRAWL_API_KEY=

# Research-history persistence (shared with the Railway worker)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Key for the encrypted per-visitor credential cookie (any long random string)
CONNECTIONS_SECRET=

# Protects the scheduled refresh route (/api/cron/refresh-intel)
CRON_SECRET=

# Override the Claude model (default: claude-sonnet-5)
# ANALYST_MODEL=
